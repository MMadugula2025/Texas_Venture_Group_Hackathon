import random
from openai import OpenAI

# ----------------------------
# 1️⃣ Initialize Morph client
# ----------------------------
client = OpenAI(
    api_key="YOUR_REAL_API_KEY",
    base_url="https://api.morphllm.com/v1"
)

# ----------------------------
# 2️⃣ Simple Load Prediction + Risk
# ----------------------------
def predict_load(temp):
    """Predict grid load (MW) based on temperature"""
    return 30000 + temp * 500 + random.randint(-2000, 2000)

def get_risk(load):
    """Classify risk based on predicted load"""
    if load < 50000:
        return "Low"
    elif load < 70000:
        return "Medium"
    else:
        return "High"

# Example temperature input
temp_input = 102  # You can change this value

predicted_load = predict_load(temp_input)
risk_level = get_risk(predicted_load)

print("Forecast Temperature:", temp_input, "°F")
print("Predicted Load (MW):", predicted_load)
print("Risk Level:", risk_level)

