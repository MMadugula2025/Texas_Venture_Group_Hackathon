import random
from openai import OpenAI
import streamlit as st

# ----------------------------
# 1️⃣ Initialize Morph client
# ----------------------------
client = OpenAI(
    api_key="YOUR_REAL_API_KEY",  # replace with your Morph API key
    base_url="https://api.morphllm.com/v1"
)

# ----------------------------
# 2️⃣ Load Prediction + Risk Functions
# ----------------------------
def predict_load(temp):
    """Predict grid load (MW) based on temperature"""
    return 30000 + temp * 500 + random.randint(-2000, 2000)

def get_risk(load):
    """Classify risk based on predicted load"""
    if load < 50000:
        return "Low"
    elif load < 70000:
        return "Medium"
    else:
        return "High"

# ----------------------------
# 3️⃣ Streamlit UI
# ----------------------------
st.title("⚡ AI Grid Stress Predictor (Morph Hackathon)")

# User input
temp_input = st.number_input("Enter forecast temperature (°F):", min_value=-20, max_value=120, value=102, step=1)

# Predict load and risk
predicted_load = predict_load(temp_input)
risk_level = get_risk(predicted_load)

st.subheader("📊 Prediction Results")
st.write(f"Forecast Temperature: {temp_input}°F")
st.write(f"Predicted Load (MW): {predicted_load}")
st.write(f"Risk Level: {risk_level}")

# ----------------------------
# 4️⃣ Morph AI Explanation
# ----------------------------
if st.button("Generate AI Explanation"):
    # Prepare code snippet for Morph
    initial_code = f"""
predicted_load = {predicted_load}
risk_level = "{risk_level}"
temp_input = {temp_input}
"""

    instructions = """
Explain why the predicted grid load and risk level are as they are
based on the forecast temperature.
Give a simple plain-language explanation and one mitigation suggestion.
Keep it under 100 words.
"""

    code_edit = "// Generate AI explanation for risk"

    response = client.chat.completions.create(
        model="morph-v3-fast",
        messages=[
            {
                "role": "user",
                "content": f"<instruction>{instructions}</instruction>\n<code>{initial_code}</code>\n<update>{code_edit}</update>"
            }
        ]
    )

    explanation = response.choices[0].message.content
    st.subheader("💡 AI Explanation")
    st.write(explanation)
